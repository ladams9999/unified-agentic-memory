# UAM application environment variables
# Copy this file to .env and fill in your values.

# --- Embedding provider ---
# Which provider to use for generating embeddings.
# Options: "ollama" (default, local) | "openai"
UAM_EMBEDDING_PROVIDER=ollama

# --- LLM provider ---
# Which provider to use for the dream-phase language model.
# Options: "ollama" (default, local) | "openai" | "openrouter"
UAM_LLM_PROVIDER=ollama

# --- Ollama (local, default) ---
UAM_OLLAMA_URL=http://localhost:11434
UAM_EMBEDDING_MODEL=nomic-embed-text
UAM_LLM_MODEL=mistral

# --- OpenAI ---
UAM_OPENAI_API_KEY=
UAM_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
UAM_OPENAI_LLM_MODEL=gpt-4o-mini
UAM_OPENAI_BASE_URL=https://api.openai.com/v1

# --- OpenRouter ---
UAM_OPENROUTER_API_KEY=
UAM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
UAM_OPENROUTER_LLM_MODEL=mistralai/mistral-7b-instruct

# --- Database ---
# Matches db_stack/.env values; override if your Postgres is elsewhere.
UAM_DB_HOST=localhost
UAM_DB_PORT=3081
UAM_DB_USER=uam_user
UAM_DB_PASSWORD=uam_password
UAM_DB_NAME=uam_db
# SSL mode for the Postgres connection.
# Options: disable | allow | prefer | require | verify-ca | verify-full
# Use "require" for Supabase or any remote Postgres with TLS.
UAM_DB_SSLMODE=prefer
# Set to true when connecting to a Postgres server without Apache AGE (e.g. Supabase).
# Graph traversal is disabled; all other features work normally.
UAM_DISABLE_GRAPH=false

# --- Tuning (rarely need changing) ---
UAM_LLM_TIMEOUT_SECONDS=300
UAM_SEARCH_CACHE_TTL_SECONDS=900
UAM_HOOK_METRICS_WINDOW=200
UAM_LOCAL_LOG_DIR=logs
