{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "powershell": "uv run python -m uam.hooks.handler --client copilot<UAM_PROFILE_ARGS>",
        "cwd": "<UAM_PROJECT_DIR>",
        "timeoutSec": 30
      }
    ]
  }
}
