# Docker Compose Postgres credentials (used by the pguam container)
PG_PORT=3081
PG_USER=uam_user
PG_PASSWORD=uam_password
PG_DB=uam_db

# UAM application settings (read from root .env or here via pydantic-settings)
# See root .env.example for the full list of UAM_ variables.

# SSL mode for the Postgres connection.
# Options: disable | allow | prefer | require | verify-ca | verify-full
# Use "require" for Supabase or any remote Postgres with TLS.
UAM_DB_SSLMODE=prefer

# Set to true when connecting to a Postgres server without Apache AGE installed
# (e.g. Supabase). Graph traversal (NEXT_EVENT chains, graph nodes) is disabled;
# all other features (events, memories, hybrid search, dream, session timeline, MCP) work normally.
UAM_DISABLE_GRAPH=false
