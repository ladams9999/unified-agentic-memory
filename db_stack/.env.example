PG_PORT=3081
PG_USER=uam_user
PG_PASSWORD=uam_password
PG_DB=uam_db

# SSL mode for the Postgres connection.
# Options: disable | allow | prefer | require | verify-ca | verify-full
# Use "require" for Supabase or any remote Postgres with TLS.
UAM_DB_SSLMODE=prefer

# Set to true when connecting to a Postgres server without Apache AGE installed
# (e.g. Supabase). Graph projection and session timeline features are disabled;
# all other features (events, memories, hybrid search, dream, MCP) work normally.
UAM_DISABLE_GRAPH=false
